# Copy this file to .env.local for local testing, or add these as
# Environment Variables in your Vercel project settings for the live deployment.

# The ID from your Google Sheet URL — the long string between /d/ and /edit
GOOGLE_SHEET_ID=1fGO_RU05Vxf9LdMN-GamuZI10RrDFGzoII9sV8hx9NU

# From the service account JSON file Google gives you (see SETUP.md)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Created automatically when you enable Vercel Blob storage on your project
# (see SETUP.md) — you don't need to fill this in by hand.
BLOB_READ_WRITE_TOKEN=
